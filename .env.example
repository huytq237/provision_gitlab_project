# Copy file này thành .env và điền giá trị thực
# Với CI/CD: set các biến này trong GitLab CI/CD Variables (masked)

# Group gốc chứa toàn bộ cấu trúc (mặc định: ocb)
ROOT_GROUP=ocb

# GitLab EE (gitlab-dso.ocb.vn)
EE_URL=http://localhost:8080
EE_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# GitLab CE (git.ocb.vn)
CE_URL=http://localhost:8081
CE_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# ── Audit Service ─────────────────────────────────────────────────
# Port webhook server lắng nghe (GitLab system hook sẽ gọi vào đây)
WEBHOOK_PORT=9000

# Secret token để xác thực webhook từ GitLab (đặt cùng giá trị trong Admin Area → System Hooks)
WEBHOOK_SECRET=change-me-to-a-random-secret

# Khoảng thời gian giữa các lần scan định kỳ (phút)
SCAN_INTERVAL_MINUTES=60

# Đường dẫn file SQLite lưu audit findings
AUDIT_DB_PATH=data/audit.db

# ── Email Alert (SMTP) ────────────────────────────────────────────
# Địa chỉ nhận email khi phát hiện vi phạm (để trống = không gửi email)
ALERT_EMAIL=ops@example.com

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=gitlab-audit@example.com
SMTP_USER=
SMTP_PASS=
# SMTP_TLS=true dùng SMTP_SSL, false dùng STARTTLS
SMTP_TLS=true
